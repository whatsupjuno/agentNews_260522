{
  "extends": "../../tsconfig.base.json",
  "compilerOptions": {
    "module": "commonjs",
    "moduleResolution": "node",
    "outDir": "./dist",
    "baseUrl": "./",
    "incremental": true,
    "rootDir": "./src",
    "paths": {
      "@agentnews/shared": ["../../packages/shared/src/index.ts"],
      "@agentnews/shared/*": ["../../packages/shared/src/*"]
