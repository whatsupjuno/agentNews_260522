# ============================================================
# Mobile env — Expo SDK 51+ EXPO_PUBLIC_* prefix
# EXPO_PUBLIC_* 만 Metro 가 클라이언트 번들에 inline.
# 비밀값은 절대 여기에 넣지 말 것 (모바일 번들 = 공개 정보).
# ============================================================

# API base URL.
# - 미설정 (Expo Go dev): Constants.hostUri 자동 추출 → http://<LAN IP>:3000/api/v1
# - 설정 시: 이 값을 그대로 사용 (staging/production 시)
# 예:
#   EXPO_PUBLIC_API_BASE_URL=http://123.45.67.89:3000/api/v1
#   EXPO_PUBLIC_API_BASE_URL=https://api.dailynews.app/api/v1
EXPO_PUBLIC_API_BASE_URL=

# WebSocket origin (보통 API base 와 동일 host).
# - 미설정: API base 의 origin 자동 사용 (path 제외)
# - 설정 시: 이 값 그대로 (다른 host 분리 시)
# 예:
#   EXPO_PUBLIC_WS_URL=https://api.dailynews.app
EXPO_PUBLIC_WS_URL=
