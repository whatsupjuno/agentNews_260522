{
  "expo": {
    "name": "DailyNews",
    "slug": "dailynews",
    "scheme": "dailynews",
    "version": "0.1.0",
    "orientation": "portrait",
    "icon": "./assets/icon.png",
    "userInterfaceStyle": "light",
    "newArchEnabled": false,
    "platforms": ["ios", "android", "web"],
    "web": {
      "bundler": "metro"
    },
    "splash": {
      "image": "./assets/splash.png",
      "resizeMode": "contain",
      "backgroundColor": "#f5f5f7"
    },
    "assetBundlePatterns": [
      "**/*"
    ],
    "ios": {
      "supportsTablet": false,
      "bundleIdentifier": "com.dailynews.app",
      "infoPlist": {
        "NSPhotoLibraryUsageDescription": "사진 첨부에 필요합니다.",
        "NSCameraUsageDescription": "사진 촬영에 필요합니다."
      }
    },
    "android": {
      "package": "com.dailynews.app",
      "adaptiveIcon": {
        "foregroundImage": "./assets/adaptive-icon.png",
        "backgroundColor": "#f5f5f7"
      },
      "permissions": [
        "android.permission.READ_EXTERNAL_STORAGE",
        "android.permission.POST_NOTIFICATIONS",
        "android.permission.RECORD_AUDIO"
      ]
    },
    "plugins": [
      "expo-notifications",
      "expo-document-picker",
      "expo-image-picker",
      "expo-secure-store"
    ],
    "extra": {
      "apiBaseUrl": "http://localhost:3000/api/v1",
      "eas": {
        "projectId": "9fa59ec8-bd44-456b-b0cf-7703db725c15"
      }
    },
    "owner": "whatsupjuno"
  }
}
