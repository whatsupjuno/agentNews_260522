# ============================================================
# agentNews — 환경 변수 샘플
# 실제 값은 .env (gitignored) 에 작성. 운영 환경은 Docker secret 또는 외부 주입.
# ============================================================

# ---- Database (PostgreSQL 16) ----
DATABASE_URL=postgresql://agentnews:agentnews_dev@localhost:5432/agentnews
POSTGRES_USER=agentnews
POSTGRES_PASSWORD=agentnews_dev
POSTGRES_DB=agentnews

# ---- JWT ----
# 운영은 32B 이상 랜덤. dev 는 placeholder.
JWT_ACCESS_SECRET=dev_access_secret_change_me_32bytes_min
JWT_REFRESH_SECRET=dev_refresh_secret_change_me_32bytes_min
JWT_UNLOCK_SECRET=dev_unlock_secret_change_me_32bytes_min

# ---- AES-256-GCM (메시지 본문 암호화) ----
# 32B base64. node -e "console.log(require('crypto').randomBytes(32).toString('base64'))"
MESSAGE_ENC_KEY=REPLACE_WITH_BASE64_32BYTES

# ---- HMAC-SHA256 (시퀀스 해시) ----
SEQUENCE_HMAC_KEY=REPLACE_WITH_RANDOM_KEY

# ---- MinIO (S3 호환 첨부 저장소) ----
MINIO_ENDPOINT=http://localhost:9000
MINIO_ACCESS_KEY=agentnews
MINIO_SECRET_KEY=agentnews_dev
MINIO_BUCKET=agentnews-attachments
MINIO_REGION=us-east-1

# ---- Firebase Cloud Messaging ----
FCM_PROJECT_ID=
FCM_SERVICE_ACCOUNT_JSON=

# ---- 외부 뉴스 API ----
# 후보: GNews / MediaStack / NewsAPI.org (A-007)
NEWS_API_PROVIDER=newsapi
NEWS_API_KEY=

# ---- SMTP (시퀀스 reset 메일) ----
SMTP_HOST=
SMTP_PORT=587
SMTP_USER=
SMTP_PASS=
SMTP_FROM="agentNews <noreply@example.com>"

# ---- App ----
NODE_ENV=development
BACKEND_PORT=3000
LOG_LEVEL=debug
